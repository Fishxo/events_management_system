<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Organizer Requests</title>
  <style>
    body { font-family: sans-serif; padding: 20px; }
    .request { margin-bottom: 15px; padding: 15px; border: 1px solid #ccc; border-radius: 8px; }
    .request button { margin-left: 10px; padding: 5px 10px; }
  </style>
</head>
<body>
  <h1>Pending Organizer Requests</h1>

  <% if (requests.length === 0) { %>
    <p>No pending requests</p>
  <% } %>

  <% requests.forEach(user => { %>
    <div class="request">
      <strong><%= user.attendname %></strong> - <%= user.attendemail %>
      <form action="/ADMINhomepage/<%= user._id %>/requests" method="POST" style="display:inline;">
        <input type="hidden" name="action" value="approve">
        <button type="submit">✅ Approve</button>
      </form>
      <form action="/ADMINhomepage/<%= user._id %>/requests" method="POST" style="display:inline;">
        <input type="hidden" name="action" value="deny">
        <button type="submit">❌ Deny</button>
      </form>
    </div>
  <% }) %>
</body>
</html>