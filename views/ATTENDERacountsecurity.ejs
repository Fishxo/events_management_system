<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Account Security</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  background:linear-gradient(135deg,#667eea,#764ba2);
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
}

.container{
  background:#fff;
  padding:35px;
  border-radius:20px;
  width:100%;
  max-width:500px;
  box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

.container h2{
  text-align:center;
  margin-bottom:25px;
  color:#667eea;
}

.form-group{
  margin-bottom:18px;
}

.form-group label{
  display:block;
  margin-bottom:6px;
  font-size:14px;
  color:#555;
}

.form-group input{
  width:100%;
  padding:12px;
  border-radius:10px;
  border:1px solid #ccc;
  outline:none;
  transition:0.2s;
}

.form-group input:focus{
  border-color:#667eea;
  box-shadow:0 0 5px rgba(102,126,234,0.4);
}

.actions{
  margin-top:20px;
  display:flex;
  flex-direction:column;
  gap:10px;
}

.actions-row{
  display:flex;
  justify-content:space-between;
  gap:10px;
}

button{
  flex:1;
  padding:12px;
  border:none;
  border-radius:25px;
  cursor:pointer;
  font-weight:600;
  transition:0.3s;
}

.update-btn{
  background:#667eea;
  color:#fff;
}

.update-btn:hover{
  background:#5a67d8;
}

.cancel-btn{
  background:#e5e7eb;
  color:#333;
}

.cancel-btn:hover{
  background:#d1d5db;
}

.two-step-btn{
  background:#38a169;
  color:#fff;
}

.two-step-btn:hover{
  background:#2f855a;
}

.two-step-btn.disabled{
  background:#6b7280;
}

.two-step-btn.disabled:hover{
  background:#4b5563;
}

.error-message{
  color:#e53e3e;
  font-size:12px;
  margin-top:5px;
}

.success-message{
  color:#38a169;
  font-size:14px;
  text-align:center;
  margin-bottom:15px;
}

.status-text{
  text-align:center;
  margin-top:10px;
  font-size:14px;
  color:#555;
}
</style>
</head>

<body>

<div class="container">
  <h2>Account Security</h2>

  <% if (message) { %>
    <p class="success-message"><%= message %></p>
  <% } %>

  <form action="/ATTENDERhomepage/<%= user._id %>/securityupdated" method="POST">

    <div class="form-group">
      <label>Old Password</label>
      <input type="password" name="oldPassword" placeholder="Enter current password" value="<%= user.attendpassword%>" required>
    </div>

    <div class="form-group">
      <label>New Password</label>
      <input type="password" name="newPassword" placeholder="Enter new password" required>
    </div>

    <div class="actions">
      <div class="actions-row">
        <form action="/ATTENDERhomepage/<%= user._id%>/UPDATEDpassword" method="post"><button type="submit" class="update-btn">Update Password</button></form>
        <button type="button" class="cancel-btn" onclick="window.history.back()">Cancel</button>
      </div>
      
      <% if (user.TwoStepCode) { %>
        <button type="button" class="two-step-btn disabled" onclick="alert('Two-step verification is already enabled')">Two-Step Verification Enabled</button>
      <% } else { %>
        <button type="button" class="two-step-btn" onclick="window.location.href='/ATTENDERhomepage/<%= user._id %>/two-step-verification'">Enable Two-Step Verification</button>
      <% } %>
    </div>

  </form>
  
  <% if (user.TwoStepCode) { %>
    <p class="status-text">Two-step verification is active for your account</p>
  <% } %>
</div>

</body>
</html>
