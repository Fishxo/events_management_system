<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manage Events</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:linear-gradient(135deg,#1e3c72,#2a5298);
min-height:100vh;
padding:40px;
color:white;
}

h1{
text-align:center;
margin-bottom:40px;
}

.events-container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:25px;
}

.event-card{
background:white;
color:#333;
border-radius:15px;
padding:20px;
box-shadow:0 10px 25px rgba(0,0,0,0.2);
transition:0.3s;
}

.event-card:hover{
transform:translateY(-5px);
}

.event-title{
font-size:20px;
font-weight:600;
margin-bottom:10px;
color:#2a5298;
}

.event-info{
margin:5px 0;
font-size:14px;
}

.buttons{
margin-top:15px;
display:flex;
justify-content:space-between;
}

button{
padding:8px 15px;
border:none;
border-radius:20px;
cursor:pointer;
font-size:13px;
}

.update{
background:#27ae60;
color:white;
}

.update:hover{
background:#1e8449;
}

.delete{
background:#e74c3c;
color:white;
}

.delete:hover{
background:#c0392b;
}

</style>
</head>
<body>

<h1>Manage Events</h1>

<div class="events-container">

<% even.forEach(ev => { %>

<div class="event-card">

<div class="event-title"><%= ev.title %></div>

<p class="event-info"><strong>Description:</strong> <%= ev.description %></p>
<p class="event-info"><strong>Location:</strong> <%= ev.location %></p>
<p class="event-info"><strong>Category:</strong> <%= ev.category %></p>
<p class="event-info"><strong>Price:</strong> $<%= ev.price %></p>
<p class="event-info"><strong>Capacity:</strong> <%= ev.capacity %></p>

<div class="buttons">

<form action="/ADMINhomepage/<%= ev._id %>/edit" method="get">
<button class="update">Update</button>
</form>

<form action="/ADMINhomepage/<%= ev._id %>/delete" method="post"
onsubmit="return confirm('Are you sure you want to delete this event?')">
<button class="delete">Delete</button>
</form>

</div>

</div>

<% }) %>

</div>

</body>
</html>