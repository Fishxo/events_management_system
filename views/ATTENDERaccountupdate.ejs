<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Update Account</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins',sans-serif; }
body { display:flex; min-height:100vh; background:linear-gradient(135deg,#667eea,#764ba2); }

.sidebar { width:240px; background:#1f1f2e; padding:30px 20px; color:#fff; display:flex; flex-direction:column; }
.sidebar h2 { margin-bottom:40px; text-align:center; font-weight:700; }
.nav-btn {
  width:100%;
  padding:14px 16px;
  border:none;
  border-radius:14px;
  cursor:pointer;
  font-size:15px;
  font-weight:500;
  color:#e5e7eb;
  background:linear-gradient(145deg,#2b2d42,#1f2235);
  box-shadow:0 4px 10px rgba(0,0,0,0.25);
  transition:all .25s ease;
  margin-bottom:14px;
  text-align:left;
}
.nav-btn:hover {
  transform:translateX(6px);
  background:linear-gradient(135deg,#667eea,#764ba2);
  color:white;
  box-shadow:0 8px 18px rgba(102,126,234,.35);
}
.nav-btn:active { transform:scale(.98); }
.nav-btn.active {
  background:linear-gradient(135deg,#667eea,#764ba2);
  color:white;
  box-shadow:0 8px 18px rgba(102,126,234,.35);
}

.main { flex:1; padding:40px; overflow-y:auto; background:#f5f7fb; border-top-left-radius:30px; border-bottom-left-radius:30px; }

.update-container { max-width:700px; margin:0 auto; }
.header { margin-bottom:30px; }
.header h1 { color:#333; font-size:28px; margin-bottom:8px; }
.header p { color:#666; font-size:14px; }

.form-card {
  background:#fff;
  border-radius:20px;
  padding:35px;
  box-shadow:0 10px 30px rgba(0,0,0,0.1);
}

.form-group { margin-bottom:22px; }
.form-group label {
  display:block;
  margin-bottom:8px;
  font-weight:600;
  color:#333;
  font-size:14px;
}
.form-group input,
.form-group textarea {
  width:100%;
  padding:14px 18px;
  border:2px solid #e8ecf1;
  border-radius:12px;
  font-size:15px;
  transition:all .3s ease;
  background:#f8fafc;
}
.form-group input:focus,
.form-group textarea:focus {
  outline:none;
  border-color:#667eea;
  background:#fff;
  box-shadow:0 0 0 4px rgba(102,126,234,0.15);
}
.form-group textarea { min-height:120px; resize:vertical; }
.form-group .hint { font-size:12px; color:#888; margin-top:6px; }

.btn-group { display:flex; gap:15px; margin-top:30px; }
.btn {
  flex:1;
  padding:14px 24px;
  border:none;
  border-radius:12px;
  font-size:15px;
  font-weight:600;
  cursor:pointer;
  transition:all .3s ease;
}
.btn-update {
  background:linear-gradient(135deg,#667eea,#764ba2);
  color:#fff;
  box-shadow:0 6px 20px rgba(102,126,234,0.35);
}
.btn-update:hover {
  transform:translateY(-3px);
  box-shadow:0 10px 25px rgba(102,126,234,0.45);
}
.btn-cancel {
  background:#f1f3f5;
  color:#666;
}
.btn-cancel:hover {
  background:#e8ecf1;
  transform:translateY(-3px);
}

.success-message {
  display:none;
  background:#d4edda;
  color:#155724;
  padding:15px 20px;
  border-radius:12px;
  margin-bottom:20px;
  text-align:center;
  font-weight:500;
}

.back-link {
  display:inline-flex;
  align-items:center;
  gap:8px;
  color:#667eea;
  text-decoration:none;
  font-weight:500;
  margin-bottom:20px;
  transition:all .3s ease;
}
.back-link:hover { color:#764ba2; transform:translateX(-5px); }
</style>
</head>
<body>

<div class="sidebar">
  <h2>Evently</h2>
  <form action="/ATTENDERhomepage/home" method="get"><button type="submit" class="nav-btn">🏠 Home</button></form>
  <form action="/ATTENDERhomepage/events" method="get"><button type="submit" class="nav-btn">🎉 Available Events</button></form>
  <form action="/ATTENDERhomepage/myevents" method="get"><button type="submit" class="nav-btn">📅 Joined Events</button></form>
  <% if(user.role == "organizer") {%>
    <form action="/ATTENDERhomepage/MINEevents" method="get"><button type="submit" class="nav-btn">📂 My Events</button></form>
  <%}%>
  <form action="/ATTENDERhomepage/<%= user._id%>/account" method="get"><button type="submit" class="nav-btn active">👤 My Account</button></form>
  <form action="/ATTE/logout" method="get"><button class="nav-btn" type="submit">🚪 Logout</button></form>
</div>

<div class="main">
  <a href="/ATTENDERhomepage/<%= user._id%>/account" class="back-link">← Back to Account</a>

  <div class="update-container">
    <div class="header">
      <h1>Update Your Profile</h1>
      <p>Keep your information up to date</p>
    </div>

    <div id="successMessage" class="success-message">Account updated successfully!</div>

    <div class="form-card">
      <form id="updateForm" action="/ATTENDERhomepage/<%= user._id%>/ACCOUNTupdated" method="POST">
        <div class="form-group">
          <label for="attendname">Full Name</label>
          <input type="text" id="attendname" name="attendname" value="<%= user.attendname %>" required>
        </div>

        <div class="form-group">
          <label for="attendusername">Username</label>
          <input type="text" id="attendusername" name="attendusername" value="<%= user.attendusername %>" required>
        </div>

        <div class="form-group">
          <label for="attendemail">Email Address</label>
          <input type="email" id="attendemail" name="attendemail" value="<%= user.attendemail %>" required>
        </div>

        <div class="form-group">
          <label for="attendbio">Bio</label>
          <textarea id="attendbio" name="attendbio" placeholder="Tell us about yourself..."><%= user.attendbio || '' %></textarea>
          <span class="hint">Brief description about yourself</span>
        </div>

        <div class="btn-group">
          <button type="button" class="btn btn-cancel" onclick="history.back()">Cancel</button>
          <button type="submit" class="btn btn-update">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.getElementById('updateForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const form = e.target;
  const successMsg = document.getElementById('successMessage');
  
  const formData = new URLSearchParams();
  formData.append('attendname', document.getElementById('attendname').value);
  formData.append('attendusername', document.getElementById('attendusername').value);
  formData.append('attendemail', document.getElementById('attendemail').value);
  formData.append('attendbio', document.getElementById('attendbio').value);
  
  try {
    const response = await fetch(form.action, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: formData.toString()
    });
    
    const result = await response.text();
    
    if (response.ok && result.includes('successfully')) {
      successMsg.style.display = 'block';
      setTimeout(() => {
        window.location.href = '/ATTENDERhomepage/<%= user._id%>/account';
      }, 1500);
    } else {
      alert(result || 'Failed to update account');
    }
  } catch (error) {
    alert('Something went wrong. Please try again.');
  }
});
</script>

</body>
</html>
