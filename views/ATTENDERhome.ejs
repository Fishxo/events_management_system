<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Event Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  display:flex;
  height:100vh;
  background:linear-gradient(135deg,#667eea,#764ba2);
}

/* Sidebar */
.sidebar{
  width:240px;
  background:#1f1f2e;
  padding:30px 20px;
  color:#fff;
  display:flex;
  flex-direction:column;
}

.sidebar h2{
  margin-bottom:40px;
  text-align:center;
  font-weight:700;
}

.sidebar a{
  text-decoration:none;
  color:#ccc;
  padding:12px;
  margin:8px 0;
  border-radius:8px;
  transition:0.3s;
}

.sidebar a:hover{
  background:#667eea;
  color:#fff;
}

/* Main content */
.main{
  flex:1;
  padding:40px;
  overflow-y:auto;
  background:#f5f7fb;
  border-top-left-radius:30px;
  border-bottom-left-radius:30px;
}

/* Header */
.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:30px;
}

.header h1{
  color:#333;
}

/* Event cards */
.events{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

.card{
  background:#fff;
  padding:20px;
  border-radius:15px;
  box-shadow:0 8px 20px rgba(0,0,0,0.1);
  transition:0.3s;
}

.card:hover{
  transform:translateY(-5px);
}

.card h3{
  margin-bottom:10px;
}

.card p{
  color:#555;
  font-size:14px;
  margin-bottom:15px;
}

.card button{
  padding:8px 15px;
  border:none;
  border-radius:20px;
  background:#667eea;
  color:white;
  cursor:pointer;
  transition:0.3s;
}

.card button:hover{
  background:#764ba2;
}
.stats{
  display:flex;
  gap:20px;
  margin-bottom:40px;
}

.stat-box{
  flex:1;
  background:#fff;
  padding:20px;
  border-radius:15px;
  text-align:center;
  box-shadow:0 8px 20px rgba(0,0,0,0.1);
  transition:0.3s;
}

.stat-box:hover{
  transform:translateY(-5px);
}

.stat-box h3{
  font-size:28px;
  color:#667eea;
}

.upcoming{
  margin-bottom:40px;
}

.actions{
  display:flex;
  gap:20px;
}

.actions button{
  padding:10px 20px;
  border:none;
  border-radius:25px;
  background:#667eea;
  color:white;
  cursor:pointer;
  transition:0.3s;
}

.actions button:hover{
  background:#764ba2;
}
.sidebar{
  width:240px;
  background:#1f1f2e;
  padding:30px 20px;
  color:white;
  display:flex;
  flex-direction:column;
}

.sidebar h2{
  text-align:center;
  margin-bottom:30px;
}

.sidebar form{
  margin-bottom:15px;
}

.nav-btn{
  width:100%;
  padding:12px;
  border:none;
  border-radius:12px;
  background:#2c2c3e;
  color:white;
  font-size:15px;
  cursor:pointer;
  transition:0.3s;
}

.nav-btn:hover{
  background:linear-gradient(135deg,#667eea,#764ba2);
  transform:translateX(5px);
}

.nav-btn:active{
  transform:scale(0.96);
}
</style>
</head>

<body>

<div class="sidebar">
  <h2>Evently</h2>

  <form action="/ATTE/home" method="get">
    <button type="submit" class="nav-btn">🏠 Home</button>
  </form>

  <form action="/events" method="get">
    <button type="submit" class="nav-btn">🎉 Available Events</button>
  </form>

  <form action="/myevents" method="get">
    <button type="submit" class="nav-btn">📅 My Events</button>
  </form>

  <form action="/account" method="get">
    <button type="submit" class="nav-btn">👤 My Account</button>
  </form>

</div>

<!-- Main Content -->
<div class="main">

  <!-- Welcome Section -->
  <div class="header">
    <h1>Welcome Back, <%= user.attendname %> 👋</h1>
  </div>

  <!-- Stats Section -->
  <div class="stats">
    <div class="stat-box">
      <h3>12</h3>
      <p>Available Events</p>
    </div>

    <div class="stat-box">
      <h3>3</h3>
      <p>My Registered Events</p>
    </div>

    <div class="stat-box">
      <h3>1</h3>
      <p>Upcoming This Week</p>
    </div>
  </div>

  <!-- Upcoming Event Preview -->
  <div class="upcoming">
    <h2>Next Upcoming Event</h2>
    <div class="card">
      <h3>Tech Innovation Summit</h3>
      <p>Date: April 15, 2026</p>
      <button>View Details</button>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="actions">
    <button>Browse Events</button>
    <button>My Events</button>
    <button>Update Profile</button>
  </div>

</div>

</body>
</html>