<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Event Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
/* ---------- Styles same as before ---------- */
* { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins',sans-serif; }
body { display:flex; min-height:100vh; background:linear-gradient(135deg,#667eea,#764ba2); }
.sidebar { width:240px; background:#1f1f2e; padding:30px 20px; color:#fff; display:flex; flex-direction:column; }
.sidebar h2 { margin-bottom:40px; text-align:center; font-weight:700; }
/* Sidebar Buttons */
.nav-btn {
  width:100%;
  padding:14px 16px;
  border:none;
  border-radius:14px;
  cursor:pointer;
  font-size:15px;
  font-weight:500;
  color:#e5e7eb;
  background:linear-gradient(145deg,#2b2d42,#1f2235);
  box-shadow:0 4px 10px rgba(0,0,0,0.25);
  transition:all .25s ease;
  margin-bottom:14px;
  text-align:left;
}

/* Hover */
.nav-btn:hover {
  transform:translateX(6px);
  background:linear-gradient(135deg,#667eea,#764ba2);
  color:white;
  box-shadow:0 8px 18px rgba(102,126,234,.35);
}

/* Click */
.nav-btn:active {
  transform:scale(.98);
}

/* Active page */
.nav-btn.active {
  background:linear-gradient(135deg,#667eea,#764ba2);
  color:white;
  box-shadow:0 8px 18px rgba(102,126,234,.35);
}
.organizer-btn{
  width:100%;
  padding:14px 16px;
  border:none;
  border-radius:14px;
  cursor:pointer;
  font-size:15px;
  font-weight:600;
  color:white;
  background:linear-gradient(135deg,#ff7e5f,#feb47b);
  box-shadow:0 6px 16px rgba(255,126,95,.35);
  transition:all .25s ease;
  margin-top:auto;
}

.organizer-btn:hover{
  transform:translateX(6px);
  box-shadow:0 10px 22px rgba(255,126,95,.45);
}
.main { flex:1; padding:40px; overflow-y:auto; background:#f5f7fb; border-top-left-radius:30px; border-bottom-left-radius:30px; }
.header { display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; }
.header h1 { color:#333; }
.stats { display:flex; gap:20px; margin-bottom:40px; }
.stat-box { flex:1; background:#fff; padding:20px; border-radius:15px; text-align:center; box-shadow:0 8px 20px rgba(0,0,0,0.1); transition:0.3s; }
.stat-box:hover { transform:translateY(-5px); }
.stat-box h3 { font-size:28px; color:#667eea; }
.upcoming, .actions { margin-bottom:40px; }
.card { background:#fff; padding:20px; border-radius:15px; box-shadow:0 8px 20px rgba(0,0,0,0.1); transition:0.3s; margin-bottom:15px; }
.card:hover { transform:translateY(-5px); }
.card h3 { margin-bottom:10px; }
.card p { color:#555; font-size:14px; margin-bottom:15px; }
.card button { padding:8px 15px; border:none; border-radius:20px; background:#667eea; color:white; cursor:pointer; transition:0.3s; margin-right:5px; }
.card button:hover { background:#764ba2; }
.actions button { padding:10px 20px; border:none; border-radius:25px; background:#667eea; color:white; cursor:pointer; font-weight:500; transition:0.3s; margin-right:10px; }
.actions button:hover { background:#764ba2; }
</style>
</head>

<body>

<!-- Sidebar -->
<div class="sidebar">
  <h2>Evently</h2>

  <form action="/ATTENDERhomepage/home" method="get"><button type="submit" class="nav-btn">🏠 Home</button></form>
  <form action="/ATTENDERhomepage/events" method="get"><button type="submit" class="nav-btn">🎉 Available Events</button></form>
  <form action="/ATTENDERhomepage/myevents" method="get"><button type="submit" class="nav-btn">📅 joined events</button></form>
  <% if(user.role == "organizer") {%>
    <form action="/ATTENDERhomepage/MINEevents" method="get" class="nav-btn"><button type="submit">📂 My Events</button></form>
  <%}%>
  <form action="/ATTENDERhomepage/<%= user._id%>/account" method="get"><button type="submit" class="nav-btn">👤 My Account</button></form>
  <form action="/ATTE/logout" method="get">
    <button class="nav-btn" type="submit">🚪 Logout</button>
  </form>
  <% if(user.role !== "organizer") { %>
    <!-- Only show request button for non-organizers -->
    <button class="organizer-btn" data-userid="<%= user._id %>">🎤 Request to be Organizer</button>
  <% } %>
</div>

<!-- Main Content -->
<div class="main">
  <div class="header">
    <h1>Welcome Back, <%= user.attendname %> 👋</h1>
    <% if(user.role == "organizer") {%>
       <p>you are organizer now you can create events</p>
    <%}%>
    
  </div>

  <!-- Stats Section -->
  <div class="stats">
    <div class="stat-box">
      <h3><%= even%></h3>
      <p>Available Events</p>
    </div>
    <div class="stat-box">
      <h3><%= join%></h3>
      <p>My Registered Events</p>
    </div>
    <div class="stat-box">
      <h3><%= upcome%></h3>
      <p>Upcoming This Week</p>
    </div>
  </div>

  <% if(user.role === "organizer") { %>
    <!-- Organizer Actions -->
    <div class="actions">
      <form action="/ORGAN/<%= user._id%>/CREATEevents" method="get"><button>Create New Event</button></form>
    </div>
       
    <h2>My Events</h2>
    <% events.forEach(ev => { %>
      <div class="card">
        <h3><%= ev.title %></h3>
        <p>Date: <%= new Date(ev.startDateTime).toLocaleString() %></p>
        <p>location: <%= ev.location%></p>
       
      </div>
    <% }) %>
  <% } else { %>
    <!-- Attender View -->
    <div class="upcoming">
      <h2>Next Upcoming Event</h2>
      <div class="card">
        <h3>Tech Innovation Summit</h3>
        <p>Date: April 15, 2026</p>
        <button>View Details</button>
      </div>
    </div>
  <% } %>

</div>

<!-- JS -->
<script>
document.addEventListener("DOMContentLoaded", () => {
  const btn = document.querySelector(".organizer-btn");
  if(btn) {
    const userId = btn.dataset.userid;
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const res = await fetch(`/ATTENDERhomepage/${userId}/reuiestORGANIZER`, { method: "POST" });
      const data = await res.text();
      alert(data);
    });
  }
});
</script>

</body>
</html>