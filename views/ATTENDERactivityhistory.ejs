<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Activity History</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;600&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  background:linear-gradient(135deg,#667eea,#764ba2);
  min-height:100vh;
  color:#fff;
  padding:30px;
}

/* Header */
h1{
  text-align:center;
  margin-bottom:30px;
}

/* Section */
.section{
  margin-bottom:40px;
}

/* Cards grid */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
  gap:20px;
}

/* Card */
.card{
  background:#fff;
  color:#333;
  padding:20px;
  border-radius:15px;
  box-shadow:0 8px 20px rgba(0,0,0,0.15);
  transition:0.3s;
}

.card:hover{
  transform:translateY(-5px);
}

.card h3{
  color:#667eea;
  margin-bottom:10px;
}

.card p{
  font-size:14px;
  margin-bottom:6px;
}

/* Empty text */
.empty{
  text-align:center;
  font-size:16px;
  margin-top:20px;
  opacity:0.9;
}
</style>
</head>

<body>

<h1>My Activity History</h1>

<!-- ✅ Registered Events -->
<div class="section">
  <h2>📅 Registered Events</h2>

  <% if(!eves || eves.length === 0){ %>
    <p class="empty">You have not joined any events.</p>
  <% } else { %>
    <div class="grid">
      <% eves.forEach(r => { %>
        <% if(r.eventId){ %>
          <div class="card">
            <h3><%= r.eventId.title %></h3>
            <p><strong>Date:</strong> <%= new Date(r.eventId.startDateTime).toLocaleString() %></p>
            <p><strong>Location:</strong> <%= r.eventId.location %></p>
            <p><strong>Category:</strong> <%= r.eventId.category %></p>
          </div>
        <% } %>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- ✅ Organizer Section -->
<div class="section">
  <h2>🎤 My Created Events</h2>

  <% if(use.role === "organizer"){ %>

    <% if(!own || own.length === 0){ %>
      <p class="empty">You haven't created any events yet.</p>
    <% } else { %>
      <div class="grid">
        <% own.forEach(ev => { %>
          <div class="card">
            <h3><%= ev.title %></h3>
            <p><strong>Date:</strong> <%= new Date(ev.startDateTime).toLocaleString() %></p>
            <p><strong>Location:</strong> <%= ev.location %></p>
            <p><strong>Category:</strong> <%= ev.category %></p>
            <p><strong>Price:</strong> $<%= ev.price %></p>
          </div>
        <% }) %>
      </div>
    <% } %>

  <% } else { %>
    <p class="empty">You are not an organizer.</p>
  <% } %>

</div>

</body>
</html>